// FoodHub Database Schema
// Using manual JWT authentication with Prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========================================
// ENUMS
// ========================================

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum DietaryPreference {
  REGULAR
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  KETO
  HALAL
}


// ========================================
// APPLICATION TABLES
// ========================================

model user {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  role          Role      @default(CUSTOMER)
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  address       String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts        account[]
  providerProfile providerProfile?
  orders          order[]
  reviews         review[]
  chatSessions    chatSession[]
}

model providerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  description  String?
  logo         String?
  address      String?
  phone        String?
  cuisineType  String?
  contactEmail String?
  rating       Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user   user    @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals  meal[]
  orders order[]

  @@index([userId])
}

model account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?   // Hashed password for credential provider
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  image       String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  meals meal[]
}

model meal {
  id                String            @id @default(cuid())
  providerProfileId String
  categoryId        String
  name              String
  description       String?
  price             Float
  image             String?
  dietaryPreference DietaryPreference @default(REGULAR)
  isAvailable       Boolean           @default(true)
  preparationTime   Int?              // in minutes
  avgRating         Float             @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  providerProfile providerProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  category        category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      orderItem[]
  reviews         review[]
  mealEmbedding   mealEmbedding?

  @@index([providerProfileId])
  @@index([categoryId])
}

model order {
  id                String      @id @default(cuid())
  customerId        String
  providerProfileId String
  status            OrderStatus @default(PLACED)
  deliveryAddress   String
  deliveryNotes     String?
  totalAmount       Float
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  customer        user            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  providerProfile providerProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  orderItems      orderItem[]

  @@index([customerId])
  @@index([providerProfileId])
  @@index([status])
}

model orderItem {
  id        String   @id @default(cuid())
  orderId   String
  mealId    String
  quantity  Int
  unitPrice Float
  createdAt DateTime @default(now())

  // Relations
  order order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  meal  meal  @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([mealId])
}

model review {
  id        String   @id @default(cuid())
  userId    String
  mealId    String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  // One review per user per meal
  @@unique([userId, mealId])
  @@index([mealId])
}

// ========================================
// V2 ADDITIONS
// ========================================

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model chatSession {
  id        String        @id @default(cuid())
  userId    String?       // nullable for guest sessions
  createdAt DateTime      @default(now())
  messages  chatMessage[]
  user      user?         @relation(fields: [userId], references: [id])

  @@index([userId])
}

model chatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      // 'user' | 'assistant' | 'system'
  content   String
  citations Json?       // referenced meal/provider IDs
  createdAt DateTime    @default(now())
  session   chatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model mealEmbedding {
  mealId    String   @id
  embedding Bytes    // 384-dim float32 packed
  textHash  String   // detect when meal text changed → re-embed
  updatedAt DateTime @updatedAt
  meal      meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
}
